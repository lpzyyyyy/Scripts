-- 2️⃣ Función para enviar a Discord
local function enviarADiscord(mensaje)
    local request = syn and syn.request or http and http.request or request
    if not request then 
        print("❌ No hay función request")
        return false
    end
    
    local exito, respuesta = pcall(function()
        return request({
            Url = webhookUrl,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = game:GetService("HttpService"):JSONEncode({
                content = mensaje,
                username = "Probador"
            })
        })
    end)
    
    if exito then
        print("✅ Webhook: Mensaje enviado")
        if respuesta and respuesta.StatusCode == 204 then
            print("   Código 204 = Éxito")
        end
        return true
    else
        print("❌ Webhook: Error -", tostring(respuesta))
        return false
    end
end

-- 3️⃣ Obtener whitelist de GitHub
local function obtenerWhitelist()
    local exito, resultado = pcall(function()
        return game:GetService("HttpService"):GetAsync(whitelistURL)
    end)
    
    if exito and resultado then
        print("📄 Whitelist CRUDA:", resultado)
        print("   Longitud:", #resultado)
        print("   Caracteres:", string.byte(resultado, 1, #resultado))
        
        local whitelist = {}
        for id in string.gmatch(resultado, "%d+") do
            local numId = tonumber(id)
            whitelist[numId] = true
            print("   ID encontrado:", numId)
        end
        return whitelist
    else
        print("❌ No se pudo obtener whitelist")
        print("   Error:", tostring(resultado))
        return {}
    end
end

